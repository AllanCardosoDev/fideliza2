import React, { useState, useMemo } from "react";
import { fmt } from "../utils/helpers";
import jsPDF from "jspdf";
import autoTable from "jspdf-autotable";

const INTEREST_MODES = [
  {
    value: "per_installment",
    label: "Por Parcela",
    color: "var(--green)",
    icon: "📦",
  },
  {
    value: "on_total",
    label: "Sobre o Total",
    color: "var(--gold)",
    icon: "💰",
  },
  {
    value: "compound_pure",
    label: "Compostos Puro",
    color: "var(--purple)",
    icon: "⚡",
  },
  {
    value: "price_table",
    label: "Tabela Price",
    color: "var(--green)",
    icon: "📊",
    recommended: true,
  },
  { value: "sac", label: "SAC", color: "var(--blue)", icon: "📈" },
];

function Simulador() {
  const [form, setForm] = useState({
    value: 10000,
    interestRate: 3.18,
    installments: 12,
    startDate: "2026-05-04",
  });

  const [selectedMode, setSelectedMode] = useState("price_table");
  const [showComparison, setShowComparison] = useState(true);

  const set = (field, val) => {
    setForm((prev) => ({ ...prev, [field]: val }));
  };

  // Cálculos por modo de juros
  const calculations = useMemo(() => {
    const v = form.value;
    const r = form.interestRate / 100;
    const n = form.installments;

    const results = {};

    // 1. Por Parcela (juros simples dividido igualmente)
    results.per_installment = {
      name: "Por Parcela",
      totalInterest: v * r * n,
      totalToReceive: v + v * r * n,
      installmentValue: (v + v * r * n) / n,
      rows: Array.from({ length: n }, (_, i) => {
        const due = new Date(form.startDate);
        due.setMonth(due.getMonth() + i);
        return {
          installment: i + 1,
          dueDate: due.toISOString().split("T")[0],
          payment: (v + v * r * n) / n,
          interest: (v * r * n) / n,
          amortization: v / n,
          balance: v - (v / n) * (i + 1),
        };
      }),
    };

    // 2. Sobre o Total (juros simples antecipado)
    results.on_total = {
      name: "Sobre o Total",
      totalInterest: v * r,
      totalToReceive: v + v * r,
      installmentValue: (v + v * r) / n,
      rows: Array.from({ length: n }, (_, i) => {
        const due = new Date(form.startDate);
        due.setMonth(due.getMonth() + i);
        return {
          installment: i + 1,
          dueDate: due.toISOString().split("T")[0],
          payment: (v + v * r) / n,
          interest: (v * r) / n,
          amortization: v / n,
          balance: v - (v / n) * (i + 1),
        };
      }),
    };

    // 3. Juros Compostos Puro (sem amortização progressiva)
    results.compound_pure = {
      name: "Juros Compostos Puro",
      totalToReceive: v * Math.pow(1 + r, n),
      totalInterest: v * Math.pow(1 + r, n) - v,
      installmentValue: (v * Math.pow(1 + r, n)) / n,
      rows: Array.from({ length: n }, (_, i) => {
        const due = new Date(form.startDate);
        due.setMonth(due.getMonth() + i);
        const totalFinal = v * Math.pow(1 + r, n);
        return {
          installment: i + 1,
          dueDate: due.toISOString().split("T")[0],
          payment: totalFinal / n,
          interest: (totalFinal - v) / n,
          amortization: v / n,
          balance: v - (v / n) * (i + 1),
        };
      }),
    };

    // 4. Tabela Price
    const calcPMT = (principal, rate, nInstallments) => {
      if (rate === 0) return principal / nInstallments;
      return (
        (principal * rate * Math.pow(1 + rate, nInstallments)) /
        (Math.pow(1 + rate, nInstallments) - 1)
      );
    };

    const pmt = calcPMT(v, r, n);
    let balance = v;
    const priceRows = [];
    let totalInterest = 0;

    for (let i = 1; i <= n; i++) {
      const interest = balance * r;
      const amort = pmt - interest;
      balance -= amort;
      totalInterest += interest;

      const due = new Date(form.startDate);
      due.setMonth(due.getMonth() + i - 1);

      priceRows.push({
        installment: i,
        dueDate: due.toISOString().split("T")[0],
        payment: pmt,
        interest,
        amortization: amort,
        balance: Math.max(balance, 0),
      });
    }

    results.price_table = {
      name: "Tabela Price",
      totalInterest,
      totalToReceive: pmt * n,
      installmentValue: pmt,
      rows: priceRows,
    };

    // 5. SAC (Amortização Constante)
    const amortizationConstant = v / n;
    let balanceSAC = v;
    const sacRows = [];
    let totalInterestSAC = 0;

    for (let i = 1; i <= n; i++) {
      const interestSAC = balanceSAC * r;
      totalInterestSAC += interestSAC;
      const paymentSAC = amortizationConstant + interestSAC;
      balanceSAC -= amortizationConstant;

      const due = new Date(form.startDate);
      due.setMonth(due.getMonth() + i - 1);

      sacRows.push({
        installment: i,
        dueDate: due.toISOString().split("T")[0],
        payment: paymentSAC,
        interest: interestSAC,
        amortization: amortizationConstant,
        balance: Math.max(balanceSAC, 0),
      });
    }

    results.sac = {
      name: "SAC",
      totalInterest: totalInterestSAC,
      totalToReceive: v + totalInterestSAC,
      installmentValue: "Variável",
      rows: sacRows,
    };

    return results;
  }, [form.value, form.interestRate, form.installments, form.startDate]);

  const selectedCalculation = calculations[selectedMode];

  const handleExportPDF = () => {
    const doc = new jsPDF();
    const pageWidth = doc.internal.pageSize.getWidth();

    // Header
    doc.setFillColor(30, 41, 59);
    doc.rect(0, 0, pageWidth, 25, "F");
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(18);
    doc.text("💰 Simulador de Empréstimo", 10, 16);

    // Info
    doc.setTextColor(0, 0, 0);
    doc.setFontSize(10);
    let yPos = 35;

    doc.text(`Modo: ${selectedCalculation.name}`, 10, yPos);
    yPos += 6;
    doc.text(
      `Valor: ${fmt(form.value)} | Taxa: ${form.interestRate.toFixed(2)}% a.m. | Parcelas: ${form.installments}`,
      10,
      yPos,
    );
    yPos += 10;

    // Summary
    doc.setFillColor(240, 250, 245);
    doc.rect(10, yPos, pageWidth - 20, 25, "F");
    doc.setFontSize(11);
    doc.setFont(undefined, "bold");
    doc.setTextColor(30, 41, 59);
    doc.text(
      `Total de Juros: ${fmt(selectedCalculation.totalInterest)}`,
      12,
      yPos + 8,
    );
    doc.text(
      `Total a Receber: ${fmt(selectedCalculation.totalToReceive)}`,
      12,
      yPos + 16,
    );

    yPos += 30;

    // Table
    const tableColumn = [
      "Parcela",
      "Vencimento",
      "Parcela",
      "Juros",
      "Amortização",
      "Saldo",
    ];
    const tableRows = selectedCalculation.rows.map((row) => [
      row.installment,
      row.dueDate,
      fmt(row.payment),
      fmt(row.interest),
      fmt(row.amortization),
      fmt(row.balance),
    ]);

    autoTable(doc, {
      head: [tableColumn],
      body: tableRows,
      startY: yPos,
      theme: "grid",
      styles: { fontSize: 9 },
      headStyles: { fillColor: [30, 41, 59], textColor: 255 },
    });

    doc.save(
      `simulador-${selectedMode}-${new Date().toISOString().split("T")[0]}.pdf`,
    );
  };

  return (
    <div className="page active">
      <style>{`
        /* Estilo para sliders */
        input[type="range"] {
          appearance: none;
          -webkit-appearance: none;
          width: 100%;
          height: 8px;
          background: linear-gradient(to right, #1e293b 0%, #1e293b 100%);
          outline: none;
          border-radius: 4px;
        }
        
        /* Thumb do slider chrome/edge */
        input[type="range"]::-webkit-slider-thumb {
          appearance: none;
          -webkit-appearance: none;
          width: 20px;
          height: 20px;
          background: linear-gradient(135deg, var(--gold), var(--gold));
          cursor: pointer;
          border-radius: 50%;
          border: 3px solid #0f172a;
          box-shadow: 0 2px 8px rgba(240, 200, 80, 0.4);
          transition: all 0.2s ease;
        }
        
        input[type="range"]::-webkit-slider-thumb:hover {
          transform: scale(1.15);
          box-shadow: 0 4px 12px rgba(240, 200, 80, 0.6);
        }
        
        /* Track do slider chrome/edge */
        input[type="range"]::-webkit-slider-runnable-track {
          background: linear-gradient(to right, #1e293b 0%, #1e293b 100%);
          height: 8px;
          border-radius: 4px;
        }
        
        /* Thumb do slider firefox */
        input[type="range"]::-moz-range-thumb {
          width: 20px;
          height: 20px;
          background: linear-gradient(135deg, var(--gold), var(--gold));
          cursor: pointer;
          border-radius: 50%;
          border: 3px solid #0f172a;
          box-shadow: 0 2px 8px rgba(240, 200, 80, 0.4);
          transition: all 0.2s ease;
        }
        
        input[type="range"]::-moz-range-thumb:hover {
          transform: scale(1.15);
          box-shadow: 0 4px 12px rgba(240, 200, 80, 0.6);
        }
        
        /* Track do slider firefox */
        input[type="range"]::-moz-range-track {
          background: linear-gradient(to right, #1e293b 0%, #1e293b 100%);
          height: 8px;
          border-radius: 4px;
          border: none;
        }
        
        input[type="range"]::-moz-range-progress {
          background: linear-gradient(135deg, var(--gold), var(--gold));
          height: 8px;
          border-radius: 4px;
        }
      `}</style>

      {/* Header com gradiente profissional */}
      <div
        style={{
          background: "linear-gradient(135deg, #1e293b 0%, #0f172a 100%)",
          padding: "32px 24px",
          color: "#fff",
          borderBottom: "1px solid rgba(255,255,255,0.08)",
        }}
      >
        <div style={{ maxWidth: "1600px", margin: "0 auto" }}>
          <div
            style={{
              display: "flex",
              alignItems: "center",
              gap: "16px",
              marginBottom: "8px",
            }}
          >
            <span style={{ fontSize: "2.5rem" }}>💰</span>
            <h2 style={{ margin: "0", fontSize: "2rem", fontWeight: "900" }}>
              Simulador de Empréstimo
            </h2>
          </div>
          <p style={{ margin: "0", opacity: "0.9", fontSize: "0.95rem" }}>
            Simule diferentes cenários de juros e compare os resultados em tempo
            real
          </p>
        </div>
      </div>

      {/* Grid Principal */}
      <div
        style={{
          display: "grid",
          gridTemplateColumns: "1fr 1fr",
          gap: "24px",
          padding: "32px 24px",
          maxWidth: "1600px",
          margin: "0 auto",
        }}
      >
        {/* CARD 1: Parâmetros */}
        <div
          style={{
            background: "var(--bg)",
            borderRadius: "16px",
            border: "1px solid var(--border)",
            boxShadow: "0 4px 24px rgba(240,200,80,0.08)",
            overflow: "hidden",
            transition: "box-shadow 0.3s ease",
          }}
          onMouseEnter={(e) =>
            (e.currentTarget.style.boxShadow =
              "0 12px 32px rgba(240,200,80,0.15)")
          }
          onMouseLeave={(e) =>
            (e.currentTarget.style.boxShadow =
              "0 4px 24px rgba(240,200,80,0.08)")
          }
        >
          {/* Card Header */}
          <div
            style={{
              background: "linear-gradient(135deg, #1e293b 0%, #111929 100%)",
              padding: "20px 24px",
              borderBottom: "1px solid rgba(255,255,255,0.08)",
            }}
          >
            <h3
              style={{
                margin: "0",
                color: "#fff",
                fontSize: "1.2rem",
                fontWeight: "800",
                display: "flex",
                alignItems: "center",
                gap: "8px",
              }}
            >
              ⚙️ Parâmetros de Simulação
            </h3>
          </div>

          {/* Card Body */}
          <div
            style={{
              padding: "28px 24px",
              display: "flex",
              flexDirection: "column",
              gap: "28px",
            }}
          >
            {/* Valor */}
            <div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "baseline",
                  marginBottom: "14px",
                }}
              >
                <label
                  style={{
                    fontWeight: "700",
                    fontSize: "0.95rem",
                    color: "var(--text)",
                    display: "flex",
                    alignItems: "center",
                    gap: "6px",
                  }}
                >
                  💵 Valor do Empréstimo
                </label>
                <span
                  style={{
                    fontSize: "1.4rem",
                    fontWeight: "900",
                    background: "linear-gradient(135deg, var(--gold), var(--gold))",
                    backgroundClip: "text",
                    WebkitBackgroundClip: "text",
                    WebkitTextFillColor: "transparent",
                  }}
                >
                  {fmt(form.value)}
                </span>
              </div>
              <input
                type="range"
                min="100"
                max="1000000"
                value={form.value}
                onChange={(e) => set("value", parseFloat(e.target.value))}
                style={{
                  width: "100%",
                  cursor: "pointer",
                  height: "8px",
                  borderRadius: "4px",
                }}
              />
              <input
                type="number"
                min="100"
                max="1000000"
                value={form.value}
                onChange={(e) =>
                  set("value", parseFloat(e.target.value) || 100)
                }
                style={{
                  width: "100%",
                  padding: "10px 12px",
                  border: "2px solid var(--border)",
                  borderRadius: "8px",
                  background: "var(--bg-alt)",
                  fontSize: "0.95rem",
                  fontWeight: "600",
                  color: "var(--text)",
                  transition: "all 0.2s ease",
                  marginTop: "10px",
                  cursor: "text",
                }}
                onFocus={(e) => {
                  e.target.style.borderColor = "var(--gold)";
                  e.target.style.boxShadow = "0 0 0 3px rgba(240,200,80,0.1)";
                }}
                onBlur={(e) => {
                  e.target.style.borderColor = "var(--border)";
                  e.target.style.boxShadow = "none";
                }}
              />
              <div
                style={{
                  fontSize: "0.8rem",
                  color: "var(--text-dim)",
                  marginTop: "10px",
                  display: "flex",
                  justifyContent: "space-between",
                }}
              >
                <span>🔹 R$ 100</span>
                <span>R$ 1.000.000 🔹</span>
              </div>
            </div>

            {/* Taxa */}
            <div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "baseline",
                  marginBottom: "14px",
                }}
              >
                <label
                  style={{
                    fontWeight: "700",
                    fontSize: "0.95rem",
                    color: "var(--text)",
                    display: "flex",
                    alignItems: "center",
                    gap: "6px",
                  }}
                >
                  📊 Taxa de Juros (a.m.)
                </label>
                <span
                  style={{
                    fontSize: "1.3rem",
                    fontWeight: "800",
                    color: "#fff",
                    background: "linear-gradient(135deg, var(--gold), var(--gold))",
                    padding: "6px 14px",
                    borderRadius: "20px",
                  }}
                >
                  {form.interestRate.toFixed(2)}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="20"
                step="0.01"
                value={form.interestRate}
                onChange={(e) =>
                  set("interestRate", parseFloat(e.target.value))
                }
                style={{
                  width: "100%",
                  cursor: "pointer",
                  height: "8px",
                  borderRadius: "4px",
                }}
              />
              <input
                type="number"
                min="0"
                max="20"
                step="0.01"
                value={form.interestRate}
                onChange={(e) =>
                  set("interestRate", parseFloat(e.target.value) || 0)
                }
                style={{
                  width: "100%",
                  padding: "10px 12px",
                  border: "2px solid var(--border)",
                  borderRadius: "8px",
                  background: "var(--bg-alt)",
                  fontSize: "0.95rem",
                  fontWeight: "600",
                  color: "var(--text)",
                  transition: "all 0.2s ease",
                  marginTop: "10px",
                  cursor: "text",
                }}
                onFocus={(e) => {
                  e.target.style.borderColor = "var(--gold)";
                  e.target.style.boxShadow = "0 0 0 3px rgba(240,200,80,0.1)";
                }}
                onBlur={(e) => {
                  e.target.style.borderColor = "var(--border)";
                  e.target.style.boxShadow = "none";
                }}
              />
              <div
                style={{
                  fontSize: "0.8rem",
                  color: "var(--text-dim)",
                  marginTop: "10px",
                  display: "flex",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <span>0%</span>
                <span style={{ color: "var(--green)", fontWeight: "600" }}>
                  ✓ Padrão: 3.18%
                </span>
                <span>20%</span>
              </div>
            </div>

            {/* Parcelas */}
            <div>
              <label
                style={{
                  fontWeight: "700",
                  fontSize: "0.95rem",
                  color: "var(--text)",
                  display: "block",
                  marginBottom: "10px",
                  display: "flex",
                  alignItems: "center",
                  gap: "6px",
                }}
              >
                📅 Número de Parcelas
              </label>
              <input
                type="number"
                min="1"
                max="120"
                value={form.installments}
                onChange={(e) =>
                  set("installments", parseInt(e.target.value) || 1)
                }
                style={{
                  width: "100%",
                  padding: "12px 14px",
                  border: "2px solid var(--border)",
                  borderRadius: "10px",
                  background: "var(--bg-alt)",
                  fontSize: "1rem",
                  fontWeight: "600",
                  color: "var(--text)",
                  transition: "all 0.2s ease",
                  cursor: "pointer",
                }}
                onFocus={(e) => {
                  e.target.style.borderColor = "var(--green)";
                  e.target.style.boxShadow = "0 0 0 3px rgba(52,211,153,0.1)";
                }}
                onBlur={(e) => {
                  e.target.style.borderColor = "var(--border)";
                  e.target.style.boxShadow = "none";
                }}
              />
              <div
                style={{
                  fontSize: "0.8rem",
                  color: "var(--text-dim)",
                  marginTop: "8px",
                }}
              >
                Máximo: 120 meses (10 anos)
              </div>
            </div>

            {/* Data */}
            <div>
              <label
                style={{
                  fontWeight: "700",
                  fontSize: "0.95rem",
                  color: "var(--text)",
                  display: "block",
                  marginBottom: "10px",
                  display: "flex",
                  alignItems: "center",
                  gap: "6px",
                }}
              >
                🗓️ Data de Início
              </label>
              <input
                type="date"
                value={form.startDate}
                onChange={(e) => set("startDate", e.target.value)}
                style={{
                  width: "100%",
                  padding: "12px 14px",
                  border: "2px solid var(--border)",
                  borderRadius: "10px",
                  background: "var(--bg-alt)",
                  fontSize: "1rem",
                  fontWeight: "600",
                  color: "var(--text)",
                  cursor: "pointer",
                  transition: "all 0.2s ease",
                }}
                onFocus={(e) => {
                  e.target.style.borderColor = "var(--green)";
                  e.target.style.boxShadow = "0 0 0 3px rgba(52,211,153,0.1)";
                }}
                onBlur={(e) => {
                  e.target.style.borderColor = "var(--border)";
                  e.target.style.boxShadow = "none";
                }}
              />
            </div>
          </div>
        </div>

        {/* CARD 2: Resultado */}
        <div
          style={{
            background: "var(--bg)",
            borderRadius: "16px",
            border: "1px solid var(--border)",
            boxShadow: "0 4px 24px rgba(240,200,80,0.08)",
            overflow: "hidden",
            transition: "box-shadow 0.3s ease",
          }}
          onMouseEnter={(e) =>
            (e.currentTarget.style.boxShadow =
              "0 12px 32px rgba(240,200,80,0.15)")
          }
          onMouseLeave={(e) =>
            (e.currentTarget.style.boxShadow =
              "0 4px 24px rgba(240,200,80,0.08)")
          }
        >
          {/* Card Header */}
          <div
            style={{
              background: "linear-gradient(135deg, #1e293b 0%, #111929 100%)",
              padding: "20px 24px",
              borderBottom: "1px solid rgba(255,255,255,0.08)",
            }}
          >
            <h3
              style={{
                margin: "0",
                color: "#fff",
                fontSize: "1.2rem",
                fontWeight: "800",
                display: "flex",
                alignItems: "center",
                gap: "8px",
              }}
            >
              📈 Resultado - {selectedCalculation.name}
            </h3>
          </div>

          {/* Card Body */}
          <div style={{ padding: "28px 24px" }}>
            {/* KPI Cards */}
            <div
              style={{
                display: "grid",
                gridTemplateColumns: "1fr 1fr",
                gap: "16px",
                marginBottom: "20px",
              }}
            >
              {/* Valor da Parcela */}
              <div
                style={{
                  padding: "22px",
                  background:
                    "linear-gradient(135deg, var(--bg-light) 0%, var(--bg) 100%)",
                  borderRadius: "12px",
                  color: "var(--gold)",
                  border: "1px solid rgba(255,255,255,0.10)",
                  boxShadow: "0 4px 12px rgba(240,200,80,0.1)",
                }}
              >
                <div
                  style={{
                    fontSize: "0.85rem",
                    color: "var(--text-dim)",
                    marginBottom: "10px",
                    fontWeight: "600",
                  }}
                >
                  Valor da Parcela
                </div>
                <div
                  style={{
                    fontSize: "1.9rem",
                    fontWeight: "900",
                    letterSpacing: "-0.5px",
                  }}
                >
                  {typeof selectedCalculation.installmentValue === "string"
                    ? selectedCalculation.installmentValue
                    : fmt(selectedCalculation.installmentValue)}
                </div>
              </div>

              {/* Total de Juros */}
              <div
                style={{
                  padding: "22px",
                  background:
                    "linear-gradient(135deg, var(--bg-light) 0%, var(--bg) 100%)",
                  borderRadius: "12px",
                  color: "var(--red)",
                  border: "1px solid rgba(255,255,255,0.10)",
                  boxShadow: "0 4px 12px rgba(248,113,113,0.1)",
                }}
              >
                <div
                  style={{
                    fontSize: "0.85rem",
                    color: "var(--text-dim)",
                    marginBottom: "10px",
                    fontWeight: "600",
                  }}
                >
                  Total de Juros
                </div>
                <div
                  style={{
                    fontSize: "1.9rem",
                    fontWeight: "900",
                    letterSpacing: "-0.5px",
                  }}
                >
                  {fmt(selectedCalculation.totalInterest)}
                </div>
              </div>

              {/* Total a Receber */}
              <div
                style={{
                  padding: "22px",
                  background:
                    "linear-gradient(135deg, var(--bg-light) 0%, var(--bg) 100%)",
                  borderRadius: "12px",
                  color: "var(--green)",
                  gridColumn: "1 / -1",
                  border: "1px solid rgba(255,255,255,0.10)",
                  boxShadow: "0 4px 12px rgba(52,211,153,0.1)",
                }}
              >
                <div
                  style={{
                    fontSize: "0.85rem",
                    color: "var(--text-dim)",
                    marginBottom: "10px",
                    fontWeight: "600",
                  }}
                >
                  💰 Total a Receber (Principal + Juros)
                </div>
                <div
                  style={{
                    fontSize: "2.1rem",
                    fontWeight: "900",
                    letterSpacing: "-0.5px",
                  }}
                >
                  {fmt(selectedCalculation.totalToReceive)}
                </div>
              </div>
            </div>

            {/* Info Adicional */}
            <div
              style={{
                background: "rgba(240,200,80,0.08)",
                padding: "16px 18px",
                borderRadius: "10px",
                borderLeft: "4px solid var(--gold)",
                fontSize: "0.92rem",
                color: "var(--text-dim)",
                display: "flex",
                justifyContent: "space-between",
                alignItems: "center",
              }}
            >
              <div>
                <strong style={{ color: "var(--text)" }}>
                  Percentual de Juros:
                </strong>{" "}
                {(
                  (selectedCalculation.totalInterest /
                    selectedCalculation.totalToReceive) *
                  100
                ).toFixed(2)}
                %
              </div>
              <button
                onClick={handleExportPDF}
                style={{
                  padding: "8px 16px",
                  background: "var(--gold)",
                  color: "#000",
                  border: "none",
                  borderRadius: "6px",
                  fontWeight: "700",
                  cursor: "pointer",
                  fontSize: "0.9rem",
                  transition: "all 0.2s ease",
                }}
                onMouseEnter={(e) => {
                  e.target.style.transform = "translateY(-2px)";
                  e.target.style.boxShadow = "0 4px 12px rgba(240,200,80,0.3)";
                }}
                onMouseLeave={(e) => {
                  e.target.style.transform = "none";
                  e.target.style.boxShadow = "none";
                }}
              >
                📥 Exportar PDF
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* Seletor de Modo e Tabela */}
      <div
        style={{
          padding: "0 24px 32px",
          maxWidth: "1600px",
          margin: "0 auto",
        }}
      >
        {/* Modo de Juros */}
        <div
          style={{
            marginBottom: "24px",
            background: "var(--bg)",
            borderRadius: "16px",
            border: "1px solid var(--border)",
            padding: "24px",
          }}
        >
          <h3
            style={{
              margin: "0 0 16px 0",
              color: "var(--text)",
              fontSize: "1.1rem",
              fontWeight: "800",
              display: "flex",
              alignItems: "center",
              gap: "8px",
            }}
          >
            🔄 Modo de Juros
          </h3>
          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(200px, 1fr))",
              gap: "16px",
            }}
          >
            {INTEREST_MODES.map((mode) => (
              <button
                key={mode.value}
                onClick={() => setSelectedMode(mode.value)}
                style={{
                  padding: "16px 20px",
                  border: "2px solid",
                  borderColor:
                    selectedMode === mode.value ? "var(--gold)" : "var(--border)",
                  borderRadius: "12px",
                  background:
                    selectedMode === mode.value
                      ? "rgba(240,200,80,0.1)"
                      : "var(--bg-alt)",
                  color: "var(--text)",
                  cursor: "pointer",
                  transition: "all 0.2s ease",
                  fontWeight: "700",
                  fontSize: "0.95rem",
                  display: "flex",
                  alignItems: "center",
                  gap: "8px",
                  justifyContent: "space-between",
                  textAlign: "left",
                }}
                onMouseEnter={(e) => {
                  if (selectedMode !== mode.value) {
                    e.target.style.borderColor = "var(--gold)";
                    e.target.style.background = "rgba(240,200,80,0.05)";
                  }
                }}
                onMouseLeave={(e) => {
                  if (selectedMode !== mode.value) {
                    e.target.style.borderColor = "var(--border)";
                    e.target.style.background = "var(--bg-alt)";
                  }
                }}
              >
                <span>{mode.icon}</span>
                <div style={{ flex: 1 }}>
                  <div>{mode.label}</div>
                  {mode.recommended && (
                    <div style={{ fontSize: "0.75rem", opacity: "0.7" }}>
                      ⭐ Recomendado
                    </div>
                  )}
                </div>
              </button>
            ))}
          </div>
        </div>

        {/* Tabela de Amortização */}
        <div
          style={{
            background: "var(--bg)",
            borderRadius: "16px",
            border: "1px solid var(--border)",
            overflow: "hidden",
          }}
        >
          <div
            style={{
              background: "linear-gradient(135deg, #1e293b 0%, #111929 100%)",
              padding: "20px 24px",
              borderBottom: "1px solid rgba(255,255,255,0.08)",
            }}
          >
            <h3
              style={{
                margin: "0",
                color: "#fff",
                fontSize: "1.2rem",
                fontWeight: "800",
                display: "flex",
                alignItems: "center",
                gap: "8px",
              }}
            >
              📊 Tabela de Amortização
            </h3>
          </div>

          <div
            style={{
              overflowX: "auto",
              padding: "0",
            }}
          >
            <table
              style={{
                width: "100%",
                borderCollapse: "collapse",
                fontSize: "0.9rem",
              }}
            >
              <thead>
                <tr
                  style={{
                    background: "rgba(240,200,80,0.1)",
                    borderBottom: "2px solid var(--border)",
                  }}
                >
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "left",
                      fontWeight: "700",
                      color: "var(--gold)",
                    }}
                  >
                    Parcela
                  </th>
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "center",
                      fontWeight: "700",
                      color: "var(--green)",
                    }}
                  >
                    Vencimento
                  </th>
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "right",
                      fontWeight: "700",
                      color: "var(--gold)",
                    }}
                  >
                    Valor da Parcela
                  </th>
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "right",
                      fontWeight: "700",
                      color: "var(--red)",
                    }}
                  >
                    Juros
                  </th>
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "right",
                      fontWeight: "700",
                      color: "var(--blue)",
                    }}
                  >
                    Amortização
                  </th>
                  <th
                    style={{
                      padding: "12px 16px",
                      textAlign: "right",
                      fontWeight: "700",
                      color: "var(--green)",
                    }}
                  >
                    Saldo Devedor
                  </th>
                </tr>
              </thead>
              <tbody>
                {selectedCalculation.rows.map((row, idx) => (
                  <tr
                    key={idx}
                    style={{
                      borderBottom: "1px solid var(--border)",
                      background:
                        idx % 2 === 0
                          ? "rgba(240,200,80,0.02)"
                          : "transparent",
                      transition: "background 0.2s ease",
                    }}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.background = "rgba(240,200,80,0.08)";
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.background =
                        idx % 2 === 0
                          ? "rgba(240,200,80,0.02)"
                          : "transparent";
                    }}
                  >
                    <td
                      style={{
                        padding: "12px 16px",
                        fontWeight: "600",
                        color: "var(--gold)",
                      }}
                    >
                      {row.installment}
                    </td>
                    <td
                      style={{
                        padding: "12px 16px",
                        textAlign: "center",
                        color: "var(--green)",
                      }}
                    >
                      {row.dueDate}
                    </td>
                    <td
                      style={{
                        padding: "12px 16px",
                        textAlign: "right",
                        color: "var(--gold)",
                        fontWeight: "600",
                      }}
                    >
                      {fmt(row.payment)}
                    </td>
                    <td
                      style={{
                        padding: "12px 16px",
                        textAlign: "right",
                        color: "var(--red)",
                      }}
                    >
                      {fmt(row.interest)}
                    </td>
                    <td
                      style={{
                        padding: "12px 16px",
                        textAlign: "right",
                        color: "var(--blue)",
                      }}
                    >
                      {fmt(row.amortization)}
                    </td>
                    <td
                      style={{
                        padding: "12px 16px",
                        textAlign: "right",
                        color: "var(--green)",
                        fontWeight: "600",
                      }}
                    >
                      {fmt(row.balance)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
}

export default Simulador;
